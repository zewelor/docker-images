{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "github-actions"
  ],
  "dependencyDashboard": true,
  "timezone": "Europe/Lisbon",
  "schedule": [
    "* 0-3 1 * *"
  ],
  "automergeSchedule": [
    "* 0-3 1 * *"
  ],
  "updateNotScheduled": false,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": false
    }
  ]
}
