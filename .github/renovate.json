{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabledManagers": [
    "github-actions",
    "dockerfile",
    "custom.regex"
  ],
  "dependencyDashboard": true,
  "timezone": "Europe/Lisbon",
  "minimumReleaseAge": "14 days",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["ARG ALPINE_VERSION=(?<currentValue>[0-9]+\\.[0-9]+)"],
      "depNameTemplate": "alpine",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s+ARG \\w+_VERSION=(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions",
        "dockerfile",
        "custom.regex"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": false
    },
    {
      "matchPackageNames": [
        "dhi.io/**"
      ],
      "enabled": false
    }
  ]
}

